# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=mydb
DB_ECHO=false

# Connection pool
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_ECHO_POOL=false

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie settings (set SECURE=true and SAMESITE=strict in production)
AUTH_ACCESS_TOKEN_NAME=access_token
AUTH_REFRESH_TOKEN_NAME=refresh_token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict

# ── Redis ─────────────────────────────────────────────────────────────────────
# Formats:
#   redis://localhost:6379
#   redis://:password@localhost:6379
#   redis://username:password@redis-host:6379/0
REDIS_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING

# ── Tests ─────────────────────────────────────────────────────────────────────
# Override test database name (default: ${DB_NAME}_test)
# TEST_DB_NAME=mydb_test
